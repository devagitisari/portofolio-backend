                {
                    "name": "Create Project",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "title",
                                    "value": "My Portofolio Website",
                                    "type": "text"
                                },
                                {
                                    "key": "description",
                                    "value": "A beautiful portofolio website",
                                    "type": "text"
                                },
                                {
                                    "key": "category",
                                    "value": "Web Development",
                                    "type": "text"
                                },
                                {
                                    "key": "status",
                                    "value": "published",
                                    "type": "text"
                                },
                                {
                                    "key": "featured",
                                    "value": "true",
                                    "type": "text"
                                },
                                {
                                    "key": "demo_url",
                                    "value": "https://example.com",
                                    "type": "text"
                                },
                                {
                                    "key": "github_url",
                                    "value": "https://github.com/username/repo",
                                    "type": "text"
                                },
                                {
                                    "key": "thumbnail",
                                    "type": "file",
                                    "src": []
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/admin/projects",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "admin",
                                "projects"
                            ]
                        }
                    }
                },
                {
                    "name": "Update Project",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"title\": \"Updated Project Title\",\n  \"description\": \"Updated description\",\n  \"category\": \"Web Development\",\n  \"status\": \"published\",\n  \"featured\": true\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/admin/projects/1",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "admin",
                                "projects",
                                "1"
                            ]
                        }
                    }
                },
                {
                    "name": "Delete Project",
                    "request": {
                        "method": "DELETE",
                        "header": [
